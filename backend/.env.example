# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transtrack

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Storage
TEMP_VIDEO_DIR=/tmp/transtrack/videos
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_DURATION_SEC=120

# Model weights (set after training in model-dev-pipeline)
MODEL_SEGMENTATION_WEIGHTS=models/segmentation/best.pt
MODEL_DETECTION_WEIGHTS=models/detection/best.pt

# Inference
FRAME_SAMPLE_FPS=3
DEVICE=cpu                  # "cpu" or "0" (GPU id)
DETECTION_CONFIDENCE=0.25
SEGMENTATION_CONFIDENCE=0.5
VEHICLE_CONFIDENCE=0.4

# Task
TASK_RESULT_TTL_SEC=86400   # 24 hours
WORKER_TIMEOUT_SEC=300      # 5 minutes
